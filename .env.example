# SecureIQ Backend Environment Variables Configuration Template
# Copy this file to a new file named '.env' in this directory and populate with actual credentials.

# PostgreSQL Connection Properties
SECUREIQ_DB_URL=jdbc:postgresql://localhost:5432/secureiq_db
SECUREIQ_DB_USERNAME=your_db_username_here
SECUREIQ_DB_PASSWORD=your_db_password_here

# JWT Configuration Parameters
# JWT_SECRET should be a secure, base64-encoded string of at least 256-bit strength
JWT_SECRET=dGhpcy1pcy1hLXNlY3VyZS1hbmQtc3VwZXItbG9uZy1zZWNyZXQta2V5LXdoaWNoLXNob3VsZC1iZS1hdC1sZWFzdC0yNTYtYml0cw==
